# ardi auto-mine config — copy to ~/.ardi-agent/auto-mine.env and edit.
#
# After editing:
#   chmod 600 ~/.ardi-agent/auto-mine.env
#   systemctl --user restart ardi-mine.timer  (or system-level if you installed root)

# ─── Runtime selection ────────────────────────────────────────────
# Which LLM agent framework runs each mining tick:
#   claude              — Claude Code CLI (default; best Chinese/Japanese riddle solving)
#   hermes              — NousResearch Hermes (auto-loads ardi skill)
#   openclaw-scripted   — OpenClaw via --message --local
# (For OpenClaw built-in 30-min heartbeat instead of systemd timer, see
#  ../openclaw-heartbeat-mode/README.md)
ARDI_AGENT_RUNTIME=claude

# ─── ardi-agent CLI ───────────────────────────────────────────────
# Path to the ardi-agent binary. Defaults to "ardi-agent" on PATH.
ARDI_AGENT_BIN=/usr/local/bin/ardi-agent

# Coord-rs API base URL. Empty = use skill default (https://api.ardinals.com).
# Override only if you run a private coordinator.
ARDI_SERVER=

# ─── Mining behavior ──────────────────────────────────────────────
# Max riddles to commit per epoch. Contract caps at 5; pick lower to
# save LLM tokens / gas / bond. The subagent will pick the highest-
# confidence riddles up to this limit.
MAX_PER_EPOCH=3

# ─── LLM API keys (provider depends on your runtime) ──────────────
# claude / hermes / openclaw all support Anthropic via this key.
# (Hermes / OpenClaw can use other providers — see their docs.)
ANTHROPIC_API_KEY=

# ─── Wallet (for ardi-agent CLI to sign txs) ──────────────────────
# Skill uses awp-wallet for signing — no raw private key needed here.
# But ardi-agent needs to know which wallet to use. The skill's default
# behavior reads ~/.awp-wallet/ — usually no env var needed.

# ─── ETH balance auto-refill (optional) ───────────────────────────
# If set, the agent will refuse to commit when ETH balance falls below
# this many wei (default 0.001 ETH = enough for ~5 cycles). Reload by
# topping up the agent wallet on Base mainnet.
ARDI_MIN_ETH_WEI=1000000000000000

# ─── Debug ────────────────────────────────────────────────────────
# Verbose stderr from ardi-agent CLI. Empty = quiet.
ARDI_DEBUG=
